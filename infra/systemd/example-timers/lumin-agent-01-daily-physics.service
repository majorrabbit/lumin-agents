[Unit]
Description=Lumin Agent 01 Resonance — Daily Physics Update
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=lumin
Group=lumin
WorkingDirectory=/opt/lumin-agents
EnvironmentFile=/opt/lumin-agents/.env
Environment=TASK=daily_physics_update

ExecStart=/opt/lumin-agents/agents/agent-01-resonance/venv/bin/python \
          /opt/lumin-agents/scripts/run_agent.py \
          agent-01-resonance daily_physics_update

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/opt/lumin-agents/agents/agent-01-resonance
TimeoutStartSec=900
Restart=no
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lumin-agent-01-daily-physics
