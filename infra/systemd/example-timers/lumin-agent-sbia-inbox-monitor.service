[Unit]
Description=Lumin SBIA — Inbox Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=lumin
Group=lumin
WorkingDirectory=/opt/lumin-agents
EnvironmentFile=/opt/lumin-agents/.env
Environment=TASK=INBOX_MONITOR

ExecStart=/opt/lumin-agents/agents/agent-sbia-booking/venv/bin/python \
          /opt/lumin-agents/scripts/run_agent.py \
          agent-sbia-booking INBOX_MONITOR

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/opt/lumin-agents/agents/agent-sbia-booking
TimeoutStartSec=600
Restart=no
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lumin-agent-sbia-inbox-monitor
