[Unit]
Description=Lumin Agent 01 Resonance — Hourly Data Collection
Documentation=file:/opt/lumin-agents/infra/systemd/README.md

[Timer]
# Every hour on the hour — Chartmetric streaming data pull + entropy computation
OnCalendar=*-*-* *:00:00
AccuracySec=30s
RandomizedDelaySec=15s
Persistent=true

[Install]
WantedBy=timers.target
