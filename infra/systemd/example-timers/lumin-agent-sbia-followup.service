[Unit]
Description=Lumin SBIA — Daily Followup Dispatch
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=lumin
Group=lumin
WorkingDirectory=/opt/lumin-agents
EnvironmentFile=/opt/lumin-agents/.env
Environment=TASK=FOLLOWUP_DISPATCH

ExecStart=/opt/lumin-agents/agents/agent-sbia-booking/venv/bin/python \
          /opt/lumin-agents/scripts/run_agent.py \
          agent-sbia-booking FOLLOWUP_DISPATCH

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
ReadWritePaths=/opt/lumin-agents/agents/agent-sbia-booking
TimeoutStartSec=900
Restart=no
StandardOutput=journal
StandardError=journal
SyslogIdentifier=lumin-agent-sbia-followup
