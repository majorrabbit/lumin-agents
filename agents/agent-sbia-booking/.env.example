# SBIA — SkyBlew Booking Intelligence Agent
ANTHROPIC_API_KEY=sk-ant-...
AWS_DEFAULT_REGION=us-east-1

# Email configuration
SBIA_FROM_EMAIL=booking@2stepsabovestars.com
SBIA_REPLY_TO=booking@2stepsabovestars.com

# DynamoDB tables
SBIA_CONVENTIONS_TABLE=sbia_conventions
SBIA_OUTREACH_LOG_TABLE=sbia_outreach_log

# S3 for EPK assets and email inbox
SBIA_EPK_BUCKET=sbia-epk-assets
SBIA_EMAIL_INBOX_BUCKET=sbia-booking-inbox

# Lambda ARN for scheduled follow-ups
SBIA_FOLLOWUP_LAMBDA_ARN=arn:aws:lambda:us-east-1:ACCOUNT:function:sbia-followup-dispatcher

# Secrets Manager keys (auto-populated if using SM)
# sbia/web-search-api-key      ← Tavily or Brave Search API key
# sbia/ses-sending-identity    ← Verified SES email
# sbia/sns-alert-topic-arn     ← SNS topic ARN for H.F. alerts
# sbia/slack-webhook-url       ← Slack webhook (optional)
# sbia/epk-s3-bucket           ← S3 bucket name
# sbia/dynamodb-conventions    ← DynamoDB table name
# sbia/dynamodb-outreach-log   ← DynamoDB outreach log table
