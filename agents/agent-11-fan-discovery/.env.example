# ─── AGENT 11: FAN DISCOVERY AGENT ───────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to Git.

# Core
ANTHROPIC_API_KEY=sk-ant-...

# AWS (IAM role in Lambda for prod — only needed for local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Reddit API (register at reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# User agent must be descriptive — Reddit requires this
REDDIT_USER_AGENT=LuminFanDiscovery/1.0 (by /u/SkyBlewOfficial)

# YouTube Data API v3 (console.cloud.google.com)
YOUTUBE_API_KEY=

# TikTok Research API (apply at developers.tiktok.com/products/research-api)
# Requires TikTok developer account approval — takes 1-2 weeks
TIKTOK_RESEARCH_API_KEY=

# Chartmetric (for streaming data in discovery)
CHARTMETRIC_API_KEY=

# Slack notification webhooks
SLACK_DISCOVERY_WEBHOOK=https://hooks.slack.com/services/...

# DynamoDB table names
OUTREACH_QUEUE_TABLE=fan-discovery-outreach-queue
COMMUNITIES_TABLE=fan-discovery-communities
ENTRY_POINTS_TABLE=fan-discovery-entry-points
CONVERSIONS_TABLE=fan-discovery-conversions
