# ─── AGENT 10: CYBERSECURITY AGENT ───────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the .env file to Git.

# Core: Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# AWS (uses IAM role in Lambda — only needed for local dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Alerting
SLACK_SECURITY_WEBHOOK=https://hooks.slack.com/services/...
SNS_SECURITY_TOPIC=arn:aws:sns:us-east-1:ACCOUNT:lumin-security-alerts
SNS_CRITICAL_TOPIC=arn:aws:sns:us-east-1:ACCOUNT:lumin-critical-page

# Streaming fraud detection
CHARTMETRIC_API_KEY=

# CloudFront
CF_DISTRIBUTION_ID=EXXXXXXXXXXXXXX

# DynamoDB table names (override defaults if using different names)
SESSIONS_TABLE=skyblew-sessions
ASSET_HASHES_TABLE=security-asset-hashes
SECURITY_EVENTS_TABLE=security-events
SECURITY_ALERTS_TABLE=security-alerts
FRAUD_REPORTS_TABLE=security-fraud-reports
