# Lumin MAS — Fleet-wide environment configuration
#
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control.
# In production (EC2), this file lives at /opt/lumin-agents/.env and is
# owned by the lumin system user (chmod 600).

# ─────────────────────────────────────────────────────────────────────────────
# AWS
# ─────────────────────────────────────────────────────────────────────────────

AWS_DEFAULT_REGION=us-east-1

# Your 12-digit AWS account ID. Used for constructing ARNs and cross-service
# references. In production, retrieve via Secrets Manager (lumin/aws-account-id).
AWS_ACCOUNT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic API
# ─────────────────────────────────────────────────────────────────────────────

# PRODUCTION NOTE: Leave ANTHROPIC_API_KEY blank on EC2 and set it in AWS
# Secrets Manager at path lumin/anthropic-api-key. Every agent uses the
# get_credential() helper which checks this env var first, then falls back
# to Secrets Manager. For local development, set it here.
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO (default), WARNING, ERROR
LUMIN_LOG_LEVEL=INFO

# Log format: json (default, for CloudWatch/journalctl parsing) or text (human-readable)
LUMIN_LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────
# BOID audit table
# ─────────────────────────────────────────────────────────────────────────────

# DynamoDB table for the fleet-wide BOID action audit log.
# Default: lumin-boid-actions (created by bootstrap_aws.sh)
LUMIN_BOID_TABLE=lumin-boid-actions

# ─────────────────────────────────────────────────────────────────────────────
# Per-agent settings
# ─────────────────────────────────────────────────────────────────────────────
#
# Slack webhooks, DynamoDB table names, and agent-specific API keys live in
# each agent's own agents/<name>/.env.example.
#
# When running multiple agents from a single fleet .env file, copy the
# relevant variables from each agent's .env.example into this file.
# Variables from different agents never conflict — each agent uses a unique
# env var name (e.g., SLACK_WEBHOOK_CS for Agent 09, SLACK_WEBHOOK_BOOKING
# for SBIA, etc.).
#
# Example: to run Agent 09 and SBIA from this file, append:
#
#   # --- Agent 09: Customer Success ---
#   SLACK_WEBHOOK_CS=https://hooks.slack.com/...
#   CS_TABLE=ask-lumin-cs-tickets
#   CS_APPROVAL_TABLE=ask-lumin-cs-approval-queue
#
#   # --- SBIA: SkyBlew Booking Intelligence ---
#   SLACK_WEBHOOK_BOOKING=https://hooks.slack.com/...
#   SBIA_BOOKING_TABLE=sbia-booking-pipeline
#   SBIA_APPROVAL_TABLE=skyblew-approval-queue
#   MAILGUN_API_KEY=
#   MAILGUN_DOMAIN=
#   AIRTABLE_API_KEY=
#   AIRTABLE_BASE_ID=
